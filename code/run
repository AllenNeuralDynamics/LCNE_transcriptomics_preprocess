#!/usr/bin/env bash
set -euo pipefail

# Reproducible run script for LCNE_transcriptomics notebooks

echo "=== Starting LCNE Transcriptomics preprocessing! ==="

# Ensure output directories exist
mkdir -p /results/figures /scratch

# Link output to results for notebook compatibility
ln -sf /results /code/output 2>/dev/null || true

# Notebooks must be in /code directory to be included in reproducible runs
# Paths are relative to /code (working directory)
# Order matters: snRNA notebooks first (generate gene lists), then MERFISH/Retro notebooks (use gene lists)
NOTEBOOKS=(
    "notebooks/snRNAseq/01_remove_chromosomal_XY.ipynb"
    "notebooks/snRNAseq/02_snRNA_batchcorrection.ipynb"
    "notebooks/merfish/MERFISH_preprocess.ipynb"
    "notebooks/retroseq/00_b_create_adata_from_raw.ipynb"
)

# Run each notebook
for notebook in "${NOTEBOOKS[@]}"; do
    echo ""
    echo ">>> Executing: $notebook"
    if [[ -f "$notebook" ]]; then
        jupyter nbconvert --to notebook --execute --inplace \
            --ExecutePreprocessor.timeout=600 "$notebook"
        echo "✓ Completed: $notebook"
    else
        echo "ERROR: File not found: $notebook"
        exit 1
    fi
done

echo ""
echo "=== All notebooks completed successfully !!!==="
echo "Results in /results"

